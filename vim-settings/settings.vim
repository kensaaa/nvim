syntax on

set mouse=a
set noerrorbells
set sw=4
set expandtab
set smartindent
set numberwidth=1
set number
set rnu
set nowrap
set noswapfile
set nobackup
set incsearch
set clipboard=unnamedplus
set encoding=utf-8
set ignorecase
set cursorline
set splitbelow
set splitright

set colorcolumn=120
highlight ColoColumn ctermbg=0 guibg=lightgrey


